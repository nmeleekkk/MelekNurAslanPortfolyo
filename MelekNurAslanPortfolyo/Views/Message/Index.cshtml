@model List<MelekNurAslanPortfolyo.Models.ContactMessage>

@{
    ViewData["Title"] = "Gelen Mesajlar";
    Layout = "_AdminLayout";
}

<div class="container mt-4">
    <h2 class="mb-4">Gelen Mesajlar</h2>
    <hr />

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">Henüz hiç mesajınız bulunmuyor.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Gönderen</th>
                        <th>E-posta</th>
                        <th>Konu</th>
                        <th>Mesaj</th>
                        <th>Tarih</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Name</strong></td>
                            <td>@item.Email</td>
                            <td>@item.Subject</td>
                            <td>@item.Message</td>
                            <td class="text-muted">@item.SendDate.ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>