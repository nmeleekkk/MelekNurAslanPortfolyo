@model List<MelekNurAslanPortfolyo.Models.ContactMessage>

@{
    ViewData["Title"] = "Gelen Mesajlar";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4 mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between border-bottom">
            <h5 class="m-0 font-weight-bold text-primary">
                Gelen Mesaj Kutusu
            </h5>
            <span class="badge badge-pill badge-primary px-3 py-2">Toplam: @Model.Count</span>
        </div>
        <div class="card-body p-0">
            @if (Model.Count == 0)
            {
                <div class="p-5 text-center">
                    <div class="alert alert-info d-inline-block m-0 px-5">Henüz hiç mesajınız bulunmuyor.</div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted text-uppercase th-sm" style="font-size: 0.85rem;">
                            <tr>
                                <th style="width: 20%; padding: 15px;">Gönderen</th>
                                <th style="width: 20%; padding: 15px;">E-posta</th>
                                <th style="width: 20%; padding: 15px;">Konu</th>
                                <th style="width: 25%; padding: 15px;">Mesaj</th>
                                <th style="width: 15%; padding: 15px;" class="text-right">Tarih</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td style="padding: 15px;">
                                        <span class="font-weight-bold text-dark">@item.Name</span>
                                    </td>
                                    <td style="padding: 15px;">
                                        <a href="mailto:@item.Email" class="text-muted text-decoration-none">@item.Email</a>
                                    </td>
                                    <td style="padding: 15px;">
                                        <span class="text-dark font-weight-500">@item.Subject</span>
                                    </td>
                                    <td style="padding: 15px;">
                                        <div class="text-truncate text-muted" style="max-width: 300px;" title="@item.Message">
                                            @(item.Message?.Length > 45 ? item.Message.Substring(0, 45) + "..." : item.Message)
                                        </div>
                                    </td>
                                    <td style="padding: 15px;" class="text-right">
                                        <span class="text-muted small font-weight-bold">@item.SendDate.ToString("dd.MM.yyyy HH:mm")</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>