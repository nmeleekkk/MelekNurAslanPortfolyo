@model List<MelekNurAslanPortfolyo.Models.Education>
@{ Layout = "_AdminLayout"; }
<div class="card mt-3">
    <div class="card-header"><h3>Eğitim Hayatım</h3></div>
    <div class="card-body">
        <table class="table table-bordered">
            <thead><tr><th>Okul</th><th>Bölüm</th><th>Yıllar</th><th>Sil</th><th>Güncelle</th></tr></thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.SchoolName</td>
                        <td>@item.Department</td>
                        <td>@item.Years</td>
                        <td><a href="/Education/Delete/@item.Id" class="btn btn-danger btn-sm">Sil</a></td>
                        <td><a href="/Education/Edit/@item.Id" class="btn btn-warning btn-sm">Güncelle</a></td>
                    </tr>
}
            </tbody>
        </table>
        <a href="/Education/Create" class="btn btn-primary">Yeni Eğitim Ekle</a>
    </div>
</div>