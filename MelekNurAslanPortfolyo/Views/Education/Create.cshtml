@model MelekNurAslanPortfolyo.Models.Education
@{ Layout = "_AdminLayout"; }
<div class="card mt-3">
    <div class="card-body">
        <form method="post">
            <div class="mb-3"><label>Okul Adı</label><input type="text" asp-for="SchoolName" class="form-control" required /></div>
            <div class="mb-3"><label>Bölüm</label><input type="text" asp-for="Department" class="form-control" required /></div>
            <div class="mb-3"><label>Yıllar</label><input type="text" asp-for="Years" class="form-control" required /></div>
            <button class="btn btn-success">Kaydet</button>
        </form>
    </div>
</div>