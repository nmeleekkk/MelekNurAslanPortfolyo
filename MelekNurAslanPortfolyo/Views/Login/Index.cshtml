@model MelekNurAslanPortfolyo.Models.Admin

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin Girişi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #f4f6f9;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }

        .login-box {
            background: white;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 400px;
        }
    </style>
</head>
<body>

    <div class="login-box">
        <h3 class="text-center mb-4">Yönetici Girişi</h3>

        <form asp-action="Index" method="post">
            <div class="mb-3">
                <label>Kullanıcı Adı</label>
                <input type="text" asp-for="Username" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Şifre</label>
                <input type="password" asp-for="Password" class="form-control" required />
            </div>

            <button type="submit" class="btn btn-primary w-100">Giriş Yap</button>
        </form>
    </div>

</body>
</html>