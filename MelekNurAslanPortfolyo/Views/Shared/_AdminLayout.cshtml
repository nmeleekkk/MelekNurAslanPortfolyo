<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Paneli</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        body {
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            background-color: #f4f6f9;
        }

        /* Sol Menü Tasarımı */
        .sidebar {
            width: 250px;
            background-color: #212529;
            color: white;
            padding-top: 20px;
        }

            .sidebar h4 {
                color: #fff;
                padding: 0 20px 20px 20px;
                border-bottom: 1px solid #4f5962;
                margin-bottom: 20px;
            }

            .sidebar a {
                color: #c2c7d0;
                padding: 12px 20px;
                display: block;
                text-decoration: none;
                transition: 0.2s;
            }

                .sidebar a:hover {
                    background-color: #495057;
                    color: white;
                    border-left: 4px solid #0d6efd;
                }

        /* Sağ İçerik Alanı */
        .content-area {
            flex-grow: 1;
            padding: 30px;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <h4>Yönetim Paneli</h4>
        <a href="#">Dashboard</a>
        <a asp-controller="Project" asp-action="Index">Projeler</a>
        <a href="#">Yetenekler</a>
        <a href="#">Deneyimler</a>
        <a asp-controller="Message" asp-action="Index">Mesajlar</a>
        <a href="#">Ayarlar</a>
        <br />
        <a asp-controller="Login" asp-action="LogOut" class="text-danger">Çıkış Yap</a>
    </div>

    <div class="content-area">
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>