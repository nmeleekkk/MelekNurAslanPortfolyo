@model List<MelekNurAslanPortfolyo.Models.Education>

<section id="education-timeline" class="container mt-5 mb-5">
    <h2 class="text-center mb-5" style="font-family: 'Caveat', cursive; color: #8a5a6b; font-size: 4rem;">Eğitim</h2>

    <div class="horizontal-timeline">
        <div class="timeline-line"></div>

        <div class="timeline-items">
            @foreach (var item in Model)
            {
                <div class="timeline-item">
                    <div class="timeline-dot"></div>

                    <div class="timeline-content">
                        <span class="timeline-date">@item.Years</span>
                        <h3 class="school-name">@item.SchoolName</h3>
                        <p class="department-name">@item.Department</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<style>
    .horizontal-timeline {
        position: relative;
        max-width: 900px;
        margin: 0 auto;
        padding-top: 20px;
    }

    .timeline-line {
        position: absolute;
        top: 29px;
        left: 10%;
        right: 10%;
        height: 2px;
        border-top: 2px dashed #c48b9f;
        z-index: 1;
    }

    .timeline-items {
        display: flex;
        justify-content: center;
        gap: 40px;
        position: relative;
        z-index: 2;
        flex-wrap: wrap;
    }

    .timeline-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 350px;
    }

    .timeline-dot {
        width: 20px;
        height: 20px;
        background-color: #FCFBFA;
        border: 4px solid #c48b9f;
        border-radius: 50%;
        margin-bottom: 20px;
        z-index: 3;
    }

    .timeline-content {
        background: white;
        padding: 25px;
        border-radius: 15px;
        border: 2px dashed #e8dcc6;
        text-align: center;
        width: 100%;
        transition: 0.3s;
        box-shadow: 0 4px 10px rgba(0,0,0,0.03);
    }

        .timeline-content:hover {
            transform: translateY(-8px);
            border-color: #c48b9f;
            box-shadow: 0 10px 20px rgba(196, 139, 159, 0.15);
        }

    .timeline-date {
        font-family: 'Courier Prime', monospace;
        color: #c48b9f;
        font-weight: bold;
        font-size: 1.1rem;
        display: block;
        margin-bottom: 8px;
    }

    .school-name {
        font-family: 'Special Elite', cursive;
        color: #5c4d4d;
        margin: 5px 0;
        font-size: 1.3rem;
    }

    .department-name {
        font-family: 'Courier Prime', monospace;
        font-size: 1rem;
        margin: 0;
        color: #7a7a7a;
    }

    @@media (max-width: 768px) {
        .timeline-line, .timeline-dot {
            display: none;
        }
    }
</style>