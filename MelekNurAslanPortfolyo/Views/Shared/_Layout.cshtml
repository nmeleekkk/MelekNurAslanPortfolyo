<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Melek Nur Aslan</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;600&family=Special+Elite&display=swap');

        body 
        {
            background-color: #FCFBFA;
            font-family: 'Inter', sans-serif;
            color: #5c4d4d;
            margin: 0;
            padding: 0;
        }

        .custom-navbar 
        {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 30px 10%;
        }

        .logo 
        {
            font-family: 'Special Elite', cursive;
            font-size: 36px;
            color: #c48b9f;
            text-decoration: none;
            letter-spacing: 2px;
            font-weight: normal;
        }

            .logo:hover 
            {
                color: #8a5a6b;
            }

        .nav-links 
        {
            list-style: none;
            display: flex;
            gap: 40px;
            margin: 0;
            padding: 0;
        }

            .nav-links li a {
                text-decoration: none;
                color: #7a7a7a;
                font-size: 16px;
                transition: 0.3s;
                position: relative;
                padding-bottom: 5px;
            }

                .nav-links li a:hover {
                    color: #c48b9f;
                }

                .nav-links li a.active {
                    color: #5c4d4d;
                }

                    .nav-links li a.active::after {
                        content: '';
                        position: absolute;
                        bottom: 0;
                        left: 0;
                        width: 100%;
                        height: 2px;
                        background-color: #5c4d4d;
                    }

        main {
            padding: 20px 10%;
        }
    </style>
</head>
<body>

    <nav class="custom-navbar">
        <a href="/Home/Index" class="logo">melek</a>
        <ul class="nav-links" id="mainMenu">
            <li><a href="#about" class="active">About</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const menuLinks = document.querySelectorAll('#mainMenu li a:not([href="/Login/Index"])');
        menuLinks.forEach(link => {
            link.addEventListener('click', function () {
                menuLinks.forEach(l => l.classList.remove('active'));
                this.classList.add('active');
            });
        });
    </script>
</body>
</html>