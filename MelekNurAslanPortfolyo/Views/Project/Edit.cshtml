@model MelekNurAslanPortfolyo.Models.Project

@{
    ViewData["Title"] = "Projeler Listesi";
    Layout = "_AdminLayout";
}

<div class="container mt-5">
    <h2>Projeyi Düzenle</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label">Proje Başlığı</label>
                    <input type="text" asp-for="Title" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Açıklama</label>
                    <textarea asp-for="Description" class="form-control" rows="3" required></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Yeni Görsel Yükle</label>
                    <input type="file" name="imageFile" class="form-control" />

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mt-2">
                            <small class="text-muted">Mevcut Görsel:</small><br />
                            <img src="@Model.ImageUrl" alt="Proje Görseli" style="width: 100px; border: 1px solid #ddd; border-radius: 5px;" />
                        </div>
                    }
                </div>

                <input type="hidden" asp-for="ImageUrl" />

                <div class="mb-3">
                    <label class="form-label">Kullanılan Teknolojiler</label>
                    <input type="text" asp-for="Technologies" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">GitHub URL</label>
                    <input type="text" asp-for="GithubUrl" class="form-control" required />
                </div>

                <button type="submit" class="btn btn-warning">Değişiklikleri Kaydet</button>
                <a asp-action="Index" class="btn btn-secondary">İptal</a>
            </form>
        </div>
    </div>
</div>
