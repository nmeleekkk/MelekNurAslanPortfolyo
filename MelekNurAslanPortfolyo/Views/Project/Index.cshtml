@model List<MelekNurAslanPortfolyo.Models.Project>

@{
    ViewData["Title"] = "Projeler Listesi";
    Layout = "_AdminLayout";
}
<div class="container mt-5">
    <h2>Projeler Listesi</h2>
    <a asp-action="Create" class="btn btn-primary mb-3">Yeni Proje Ekle</a>
    <hr />

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Başlık</th>
                <th>Açıklama</th>
                <th>Görsel URL</th>
                <th>GitHub URL</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>@item.ImageUrl</td>
                    <td>@item.GithubUrl</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Düzenle</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger ms-1">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>