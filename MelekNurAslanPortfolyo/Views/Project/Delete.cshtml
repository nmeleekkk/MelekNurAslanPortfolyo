@model MelekNurAslanPortfolyo.Models.Project

@{
    ViewData["Title"] = "Projeler Listesi";
    Layout = "_AdminLayout";
}

<div class="container mt-5">
    <h2 class="text-danger">Projeyi Sil</h2>
    <hr />

    <div class="alert alert-danger">
        <h4>Bu projeyi silmek istediğinize emin misiniz? Bu işlem geri alınamaz!</h4>
        <br />
        <p><strong>Başlık:</strong> @Model.Title</p>
        <p><strong>Açıklama:</strong> @Model.Description</p>
    </div>

    <div class="mt-3">
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Evet, Sil</button>
            <a asp-action="Index" class="btn btn-secondary">İptal ve Geri Dön</a>
        </form>
    </div>
</div>